APP_PASSWORD=change-this-before-lan-use
SESSION_SECRET=change-this-random-string

HERMES_COMMAND=hermes

STORAGE_DIR=storage
REPORTS_DIR=reports
DATABASE_URL=sqlite:///storage/app.db

APP_HOST=0.0.0.0
APP_PORT=8000
OCR_ENABLED=true
OCR_LANGUAGE=ch
HERMES_TIMEOUT_SECONDS=900

