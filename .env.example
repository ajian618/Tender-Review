APP_PASSWORD=change-this-before-lan-use
SESSION_SECRET=change-this-random-string

STORAGE_DIR=storage
REPORTS_DIR=reports
DATABASE_URL=sqlite:///storage/app.db

APP_HOST=0.0.0.0
APP_PORT=8000
DOCUMENT_PARSER=paddle_structure
DOCUMENT_LANGUAGE=ch
VECTOR_ENABLED=true
VECTOR_STORE_DIR=storage/qdrant
VECTOR_COLLECTION=bid_documents
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIM=512

